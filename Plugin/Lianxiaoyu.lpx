#!name = 恋小语解锁VIP
#!desc = 恋小语解锁VIP，畅快体验高情商
#!author = Wuang备份 [https://github.com/W126-L]
#!openUrl = https://raw.githubusercontent.com/W126-L/Tool/master/Plugin/Lianxiaoyu.lpx
