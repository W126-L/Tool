#!icon = https://raw.githubusercontent.com/W126-L/Tool/main/IconSet/108px/Lianxiaoyu.png
#!tag = 阿旺の

[Rewrite]
# 去广告
^https?:\//\api\.love\.823123\.com\/facades\/ad_space\.index - reject-200

[Script]
# VIP显示
http-response ^https?:\/\/api\.love\.823123\.com\/facades\/account\.show script-path=https://raw.githubusercontent.com/W126-L/Tool/master/Scripts/Lianxiaoyu.js, requires-body=true, timeout=60, tag=VIP显示, img-url=https://raw.githubusercontent.com/W126-L/Tool/main/IconSet/108px/Lianxiaoyu.png

# 小恋老师，键盘-回复它-开场白
http-request ^https?:\/\/api\.love\.823123\.com\/(facades\/open\.chat_stream|v1\/discovery\/query) script-path=https://raw.githubusercontent.com/W126-L/Tool/master/Scripts/Lianxiaoyu.js, timeout=60, tag=小恋老师键盘-回复它-开场白, img-url=https://raw.githubusercontent.com/W126-L/Tool/main/IconSet/108px/Lianxiaoyu.png

[MITM]
hostname = api.love.823123.com