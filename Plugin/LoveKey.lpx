[Script]
# 聊天
http-request https://sea.api.lovekeyboard.com/v1/chat/keyboard-stream-msg script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js, timeout=60, tag=lovekey

# 开场白
http-request https://sea.api.lovekeyboard.com/v1/chat/keyboard-ow-msg script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js, timeout=60, tag=lovekey

# 超级对话
http-request https://sea.api.lovekeyboard.com/v1/chat/stream_super_msg script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js, timeout=60, tag=lovekey

http-response https://sea.api.lovekeyboard.com/v2/account script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/lovekey.js, requires-body=true, timeout=60, tag=lovekey

[MITM]
hostname = sea.api.lovekeyboard.com