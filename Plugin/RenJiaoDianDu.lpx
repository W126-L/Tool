[Script]
http-response ^https?:\/\/.*\.mypep\.cn\/(thirdPartyService\/book_init(_v3)?\.json|user\/ak\/pep_click\/user\/.*\/userinfo\.json|loginvcode|unit\/encrypt\/detail) script-path=https://raw.githubusercontent.com/Yu9191/Rewrite/refs/heads/main/rjdd.js, requires-body=true, timeout=60, tag=人教点读, img-url=https://raw.githubusercontent.com/W126-L/Tool/main/IconSet/108px/RenJiaoDianDu.png

[MITM]
hostname = *.mypep.cn
